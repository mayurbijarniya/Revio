generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users
model User {
  id              String    @id @default(uuid()) @db.Uuid
  githubId        Int       @unique @map("github_id")
  githubUsername  String    @map("github_username") @db.VarChar(255)
  email           String?   @db.VarChar(255)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  accessToken     String    @map("access_token") @db.Text
  refreshToken    String?   @map("refresh_token") @db.Text
  tokenExpiresAt  DateTime? @map("token_expires_at")
  plan            String    @default("free") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  repositories          Repository[]
  conversations         Conversation[]
  usage                 Usage[]
  ownedOrganizations    Organization[]        @relation("OrganizationOwner")
  organizationMembers   OrganizationMember[]
  activities            Activity[]
  reviewsRequested      PrReview[]            @relation("ReviewsRequested")
  reviewsAssigned       PrReview[]            @relation("ReviewsAssigned")

  @@map("users")
}

// Organizations (for team features)
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  ownerId   String   @map("owner_id") @db.Uuid
  plan      String   @default("team") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  owner        User                   @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members      OrganizationMember[]
  repositories Repository[]
  usage        Usage[]
  activities   Activity[]
  reviewLearning ReviewLearning?

  @@map("organizations")
}

// Organization Members
model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String   @default("member") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// Repositories
model Repository {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  githubRepoId   Int       @map("github_repo_id")
  name           String    @db.VarChar(255)
  fullName       String    @map("full_name") @db.VarChar(255)
  private        Boolean   @default(false)
  defaultBranch  String    @default("main") @map("default_branch") @db.VarChar(100)
  language       String?   @db.VarChar(100)

  // Indexing
  indexStatus      String    @default("pending") @map("index_status") @db.VarChar(50)
  indexProgress    Int       @default(0) @map("index_progress")
  indexedAt        DateTime? @map("indexed_at")
  indexError       String?   @map("index_error") @db.Text
  indexQueuedAt    DateTime? @map("index_queued_at")
  indexStartedAt   DateTime? @map("index_started_at")
  indexHeartbeatAt DateTime? @map("index_heartbeat_at")
  indexJobId       String?   @map("index_job_id") @db.VarChar(255)
  fileCount        Int       @default(0) @map("file_count")
  chunkCount       Int       @default(0) @map("chunk_count")

  // Webhook
  webhookId     Int?    @map("webhook_id")
  webhookSecret String? @map("webhook_secret") @db.VarChar(255)

  // Settings
  autoReview   Boolean  @default(true) @map("auto_review")
  reviewRules  Json     @default("{}") @map("review_rules")
  ignoredPaths String[] @default([]) @map("ignored_paths")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  indexedFiles     IndexedFile[]
  conversations    Conversation[]
  prReviews        PrReview[]
  usage            Usage[]
  activities       Activity[]
  codingStandards  CodingStandards[]
  codeGraph        CodeGraph?
  botConversations BotConversation[]
  reviewLearning   ReviewLearning?

  @@unique([userId, githubRepoId])
  @@index([userId])
  @@index([indexStatus])
  @@index([indexStatus, indexQueuedAt])
  @@index([indexStatus, indexHeartbeatAt])
  @@map("repositories")
}

// Indexed Files (for incremental updates)
model IndexedFile {
  id           String   @id @default(uuid()) @db.Uuid
  repositoryId String   @map("repository_id") @db.Uuid
  filePath     String   @map("file_path") @db.VarChar(1000)
  fileHash     String   @map("file_hash") @db.VarChar(64)
  language     String?  @db.VarChar(50)
  chunkCount   Int      @default(0) @map("chunk_count")
  indexedAt    DateTime @default(now()) @map("indexed_at")

  // Relations
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, filePath])
  @@map("indexed_files")
}

// Conversations
model Conversation {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  repositoryId    String    @map("repository_id") @db.Uuid
  repositoryIds   String[]  @map("repository_ids") @default([])
  title           String?   @db.VarChar(255)
  isPinned        Boolean   @default(false) @map("is_pinned")
  mode            String    @default("indexed") @db.VarChar(20) // "indexed" | "full_repo"
  fullRepoContext Json?     @map("full_repo_context") // Cached repo files for full_repo mode
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([userId])
  @@map("conversations")
}

// Messages
model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(20)
  content        String   @db.Text
  contextChunks  Json?    @map("context_chunks")
  tokensUsed     Int      @default(0) @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// PR Reviews
model PrReview {
  id            String   @id @default(uuid()) @db.Uuid
  repositoryId  String   @map("repository_id") @db.Uuid
  prNumber      Int      @map("pr_number")
  prTitle       String?  @map("pr_title") @db.VarChar(500)
  prUrl         String?  @map("pr_url") @db.VarChar(1000)
  prAuthor      String?  @map("pr_author") @db.VarChar(255)

  // Team assignment
  requestedById String?  @map("requested_by_id") @db.Uuid
  assignedToId  String?  @map("assigned_to_id") @db.Uuid

  // Review content
  summary        String?  @db.Text
  issues         Json     @default("[]")
  suggestions    Json     @default("[]")
  filesAnalyzed  Json     @default("[]") @map("files_analyzed")
  recommendation String?  @db.VarChar(20) // "approve" | "request_changes" | "comment"
  riskLevel      String?  @map("risk_level") @db.VarChar(20) // "low" | "medium" | "high" | "critical"
  confidenceScore Int?    @map("confidence_score") @db.SmallInt // 1-5 scale for merge readiness
  sequenceDiagram String? @map("sequence_diagram") @db.Text // Mermaid diagram syntax
  docstringSuggestions Json @default("[]") @map("docstring_suggestions") // [{path, line, language, docstring, signatureLine}]
  blastRadius    Json     @default("{}") @map("blast_radius") // Impact visualization + affected nodes
  testCoverage   Json     @default("{}") @map("test_coverage") // Heuristic test-coverage signals
  headSha        String?  @map("head_sha") @db.VarChar(40)
  runCount       Int      @default(0) @map("run_count")
  queuedAt       DateTime? @map("queued_at")
  startedAt      DateTime? @map("started_at")
  jobId          String?   @map("job_id") @db.VarChar(255)

  // Status
  status          String @default("pending") @db.VarChar(50)
  githubCommentId BigInt?   @map("github_comment_id")

  // Metrics
  tokensUsed       Int @default(0) @map("tokens_used")
  processingTimeMs Int? @map("processing_time_ms")

  // Feedback
  feedback         String?   @db.VarChar(20) // "helpful" | "not_helpful" | null
  feedbackComment  String?   @map("feedback_comment") @db.Text
  feedbackAt       DateTime? @map("feedback_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  repository      Repository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  requestedBy     User?            @relation("ReviewsRequested", fields: [requestedById], references: [id], onDelete: SetNull)
  assignedTo      User?            @relation("ReviewsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  botConversation BotConversation?
  runs            PrReviewRun[]

  @@unique([repositoryId, prNumber])
  @@index([repositoryId])
  @@index([assignedToId])
  @@index([status, queuedAt])
  @@map("pr_reviews")
}

// Usage Tracking
model Usage {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actionType     String   @map("action_type") @db.VarChar(50)
  tokensInput    Int      @default(0) @map("tokens_input")
  tokensOutput   Int      @default(0) @map("tokens_output")
  repositoryId   String?  @map("repository_id") @db.Uuid
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository   Repository?   @relation(fields: [repositoryId], references: [id])

  @@index([userId, createdAt])
  @@map("usage")
}

// Activity Feed (for organizations)
model Activity {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  repositoryId   String?  @map("repository_id") @db.Uuid
  type           String   @db.VarChar(50) // repo_added, repo_removed, pr_reviewed, member_joined, member_left, settings_updated
  title          String   @db.VarChar(255)
  description    String?  @db.Text
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository   Repository?  @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("activities")
}

// Coding Standards (auto-detected from repository files)
model CodingStandards {
  id           String   @id @default(uuid()) @db.Uuid
  repositoryId String   @map("repository_id") @db.Uuid
  source       String   @db.VarChar(100) // "claude.md" | "cursorrules" | "agents.md" | "ai_folder" | "manual"
  filePath     String   @map("file_path") @db.VarChar(500) // Path to the standards file
  content      String   @db.Text // Original file content
  parsedRules  Json     @default("[]") @map("parsed_rules") // Extracted rules as structured data
  enabled      Boolean  @default(true) // Whether to use these standards in reviews
  detectedAt   DateTime @default(now()) @map("detected_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, source])
  @@index([repositoryId])
  @@map("coding_standards")
}

// Code Graph (function relationships and dependencies)
model CodeGraph {
  id           String   @id @default(uuid()) @db.Uuid
  repositoryId String   @unique @map("repository_id") @db.Uuid
  nodes        Json     // [{id, type: "function"|"class"|"file", name, file, line}]
  edges        Json     // [{from, to, type: "calls"|"imports"|"extends"}]
  metadata     Json     // {entryPoints, circularDeps, stats}
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("code_graphs")
}

// Bot Conversations (interactive @bot conversations in PR comments)
model BotConversation {
  id           String   @id @default(uuid()) @db.Uuid
  prReviewId   String   @map("pr_review_id") @db.Uuid
  repositoryId String   @map("repository_id") @db.Uuid
  prNumber     Int      @map("pr_number")
  messages     Json     @default("[]") // [{role: "user"|"bot", content, timestamp, commentId, userId}]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  prReview   PrReview   @relation(fields: [prReviewId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([prReviewId])
  @@index([repositoryId])
  @@index([prNumber])
  @@map("bot_conversations")
}

// Review Learning (team preferences, suppression, and auto-suggested rules)
model ReviewLearning {
  id                   String   @id @default(uuid()) @db.Uuid
  repositoryId         String?  @unique @map("repository_id") @db.Uuid
  organizationId       String?  @unique @map("organization_id") @db.Uuid

  // Learned patterns
  preferredPatterns     Json     @default("[]") @map("preferred_patterns") // [{pattern, frequency, examples}]
  suppressedPatterns    Json     @default("[]") @map("suppressed_patterns") // [{issueType, category, pattern, reason, suppressedAt, count}]
  customRuleSuggestions Json     @default("[]") @map("custom_rule_suggestions") // [{id, rule, source, confidence, frequency, examples, status}]

  // Feedback stats
  feedbackStats         Json     @default("{}") @map("feedback_stats") // {category: {helpful: N, notHelpful: M}}
  adoptionRates         Json     @default("{}") @map("adoption_rates") // {issueType: adoptionRate}

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  repository   Repository?   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([organizationId])
  @@map("review_learning")
}

// PR Review Runs (history of review generations for adoption tracking)
model PrReviewRun {
  id                 String   @id @default(uuid()) @db.Uuid
  prReviewId          String   @map("pr_review_id") @db.Uuid
  runNumber           Int      @map("run_number")

  headSha             String?  @map("head_sha") @db.VarChar(40)
  summary             String?  @db.Text
  issues              Json     @default("[]")
  suggestions         Json     @default("[]")
  filesAnalyzed       Json     @default("[]") @map("files_analyzed")
  recommendation      String?  @db.VarChar(20) // "approve" | "request_changes" | "comment"
  riskLevel           String?  @map("risk_level") @db.VarChar(20)
  confidenceScore     Int?     @map("confidence_score") @db.SmallInt
  sequenceDiagram     String?  @map("sequence_diagram") @db.Text
  docstringSuggestions Json    @default("[]") @map("docstring_suggestions")
  blastRadius         Json     @default("{}") @map("blast_radius")
  testCoverage        Json     @default("{}") @map("test_coverage")

  processingTimeMs    Int?     @map("processing_time_ms")
  tokensUsed          Int      @default(0) @map("tokens_used")
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  prReview PrReview @relation(fields: [prReviewId], references: [id], onDelete: Cascade)

  @@unique([prReviewId, runNumber])
  @@index([prReviewId])
  @@map("pr_review_runs")
}
