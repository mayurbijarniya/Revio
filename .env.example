# ===========================================
# REVIO - Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in your values
# ===========================================

# -----------------------------
# Database (Supabase PostgreSQL)
# -----------------------------
# Get these from your Supabase project settings > Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -----------------------------
# Authentication
# -----------------------------
# GitHub OAuth - Create at https://github.com/settings/developers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# GitHub App (for bot reviews) - Create at https://github.com/settings/apps
# The bot can approve PRs even when reviewing your own code
GITHUB_APP_ID="your_github_app_id"
GITHUB_APP_CLIENT_ID="your_github_app_client_id"
GITHUB_APP_CLIENT_SECRET="your_github_app_client_secret"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Webhook secret configured in your GitHub App settings (Webhook > Secret)
# This is used to verify incoming webhook requests are from GitHub
GITHUB_APP_WEBHOOK_SECRET="your_github_app_webhook_secret"

# Session secret - Generate with: openssl rand -base64 32
SESSION_SECRET="your_session_secret_min_32_chars"

# Encryption key for storing GitHub tokens - Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your_encryption_key_32_chars_min"

# -----------------------------
# AI Services
# -----------------------------
# OpenAI API Key - For embeddings (text-embedding-3-small)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# Google AI API Key - For Gemini chat and PR reviews
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY="your_google_ai_api_key"

# -----------------------------
# Vector Database (Qdrant Cloud)
# -----------------------------
# Get from: https://cloud.qdrant.io/
QDRANT_URL="https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_api_key"

# -----------------------------
# Redis (Upstash) - For job queues
# -----------------------------
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token"

# -----------------------------
# Application URL
# -----------------------------
# Your deployed application URL (no trailing slash)
# Use http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------
# Vercel Cron Jobs
# -----------------------------
# Secret for authenticating cron job requests
# Vercel automatically sets this when you deploy with cron jobs
# For local testing, generate with: openssl rand -base64 32
CRON_SECRET="your_cron_secret_for_vercel"

# -----------------------------
# Optional: Stripe (for payments - not required for Phase 1-3)
# -----------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_TEAM="price_..."
